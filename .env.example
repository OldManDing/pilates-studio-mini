# ============================================
# Pilates Studio Mini Program - Environment
# ============================================

# API Configuration
# For development in WeChat DevTools: local backend is OK
# For real device / production: use a deployed HTTPS backend URL and configure it
# in WeChat Mini Program Console -> Development -> Server Domains -> request domain.
API_BASE_URL=http://127.0.0.1:3000/api
DEVTOOLS_API_BASE_URL=http://127.0.0.1:3000/api
# Local real-device debugging only. Keep false for production/release builds.
ALLOW_INSECURE_REAL_DEVICE_API=false

# WeChat Mini Program (if using WeChat login)
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_SECRET=your-wechat-app-secret

# Build Configuration
NODE_ENV=development
# Set APP_ENV=production only for release builds; production requires API_BASE_URL/SUPPORT_PHONE/SUPPORT_EMAIL
APP_ENV=development
# CI/release pipelines may also set MINI_RELEASE=true to enforce production config checks
MINI_RELEASE=false

# Support contact configuration
SUPPORT_PHONE=
SUPPORT_EMAIL=

# Optional local fallback when WeChat code login is unavailable in development
MINI_OPEN_ID=dev-openid-pilates
# Local development only: force login with MINI_OPEN_ID instead of WeChat code.
USE_MINI_OPEN_ID_LOGIN=false
