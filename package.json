{
  "name": "careme-practice-mini",
  "version": "1.0.9",
  "private": true,
  "description": "CareMe练习记录小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "scss"
  },
  "scripts": {
    "clean:dist": "node scripts/clean-dist.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run verify",
    "test:smoke": "node scripts/smoke-tests.cjs",
    "test:api": "node scripts/api-smoke.cjs",
    "postinstall": "node scripts/patch-taro-doctor.cjs",
    "verify:weapp-dist": "node scripts/verify-weapp-dist.cjs",
    "verify": "npm run typecheck && npm run lint && npm run test:smoke && npm run build:weapp && npm run verify:weapp-dist",
    "prebuild:weapp": "npm run clean:dist",
    "build:weapp": "taro build --type weapp",
    "prebuild:swan": "npm run clean:dist",
    "build:swan": "taro build --type swan",
    "prebuild:alipay": "npm run clean:dist",
    "build:alipay": "taro build --type alipay",
    "prebuild:tt": "npm run clean:dist",
    "build:tt": "taro build --type tt",
    "prebuild:h5": "npm run clean:dist",
    "build:h5": "taro build --type h5",
    "prebuild:rn": "npm run clean:dist",
    "build:rn": "taro build --type rn",
    "prebuild:qq": "npm run clean:dist",
    "build:qq": "taro build --type qq",
    "prebuild:jd": "npm run clean:dist",
    "build:jd": "taro build --type jd",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "CareMe练习记录",
  "dependencies": {
    "@babel/runtime": "^7.7.7",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-decorators": "7.20.7",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-doctor": "^0.0.13",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.0.0",
    "@types/webpack-env": "^1.13.6",
    "@typescript-eslint/eslint-plugin": "^5.20.0",
    "@typescript-eslint/parser": "^5.20.0",
    "babel-preset-taro": "4.2.0",
    "css-loader": "7.1.4",
    "eslint": "^8.12.0",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.8.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "postcss": "8.5.13",
    "style-loader": "3.3.4",
    "stylelint": "14.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.1.0",
    "webpack": "5.106.2"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "glob": "13.0.6",
    "http-cache-semantics": "4.2.0",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "postcss": "8.5.13",
    "serialize-javascript": "7.0.5",
    "swiper": "12.1.4",
    "uuid": "14.0.0",
    "@tootallnate/once": "3.0.1",
    "form-data": "4.0.5",
    "qs": "6.15.1",
    "tough-cookie": "6.0.1",
    "got": "11.8.6",
    "webpack": "5.106.2",
    "webpack-dev-server": "5.2.3",
    "webpackbar": "7.0.0",
    "html-minifier": "npm:html-minifier-terser@7.2.0",
    "download-git-repo": "file:./scripts/audit-patches/download-git-repo"
  }
}
